{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "table", "name": "Table" }
  ],
  "id": null,
  "uid": "siclaw-overview",
  "title": "Siclaw Overview",
  "description": "Siclaw SRE Copilot — sessions, prompts, tokens, cost, tools, and health",
  "tags": ["siclaw"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(siclaw_prompts_total, provider)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Active Sessions",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "sum(siclaw_sessions_active)", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "WebSocket Connections",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "sum(siclaw_ws_connections)", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Prompts / min",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "sum(rate(siclaw_prompts_total{provider=~\"$provider\"}[5m])) * 60", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [{
        "expr": "sum(rate(siclaw_prompts_total{outcome=\"error\",provider=~\"$provider\"}[5m])) / sum(rate(siclaw_prompts_total{provider=~\"$provider\"}[5m]))",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "title": "Cost ($/hour)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{ "expr": "sum(rate(siclaw_cost_usd_total{provider=~\"$provider\"}[1h])) * 3600", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Stuck Sessions",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{ "expr": "sum(increase(siclaw_session_stuck_total[10m]))", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Cost & Tokens",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Cost Over Time ($/hour)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{
        "expr": "sum by (provider) (rate(siclaw_cost_usd_total{provider=~\"$provider\"}[5m])) * 3600",
        "legendFormat": "{{ provider }}"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Token Consumption Rate (tokens/min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "sum by (type) (rate(siclaw_tokens_total{provider=~\"$provider\"}[5m])) * 60", "legendFormat": "{{ type }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Prompt Duration Percentiles",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(siclaw_prompt_duration_ms_bucket{provider=~\"$provider\"}[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(siclaw_prompt_duration_ms_bucket{provider=~\"$provider\"}[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(siclaw_prompt_duration_ms_bucket{provider=~\"$provider\"}[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 5 } } }
    },
    {
      "title": "Prompt Rate by Outcome",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        { "expr": "sum by (outcome) (rate(siclaw_prompts_total{provider=~\"$provider\"}[5m])) * 60", "legendFormat": "{{ outcome }}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "completed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "Tools",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "title": "Tool Calls / min (Top 10)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [{
        "expr": "topk(10, sum by (tool_name) (rate(siclaw_tool_calls_total[5m]))) * 60",
        "legendFormat": "{{ tool_name }}"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Tool Error Rate by Name",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [{
        "expr": "sum by (tool_name) (rate(siclaw_tool_calls_total{outcome=\"error\"}[5m])) / sum by (tool_name) (rate(siclaw_tool_calls_total[5m]))",
        "legendFormat": "{{ tool_name }}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "title": "Active Sessions Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "targets": [{ "expr": "sum(siclaw_sessions_active)", "legendFormat": "sessions" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "WebSocket Connections Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "targets": [{ "expr": "sum(siclaw_ws_connections)", "legendFormat": "connections" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Context Window Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "targets": [
        { "expr": "sum(siclaw_context_tokens_used)", "legendFormat": "used" },
        { "expr": "sum(siclaw_context_tokens_limit)", "legendFormat": "limit" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    }
  ]
}
