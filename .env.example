# Siclaw Environment Variables
# All variables below are optional for Personal Server mode.
# The server starts with smart defaults — configure LLM providers in the web UI.

# === Personal Server (all optional, has smart defaults) ===
# SICLAW_LLM_API_KEY=           # Or configure in web UI: Settings > Models
# SICLAW_DATABASE_URL=          # Default: sqlite:.siclaw/data.sqlite
# SICLAW_JWT_SECRET=            # Default: auto-generated on first run
# SICLAW_ADMIN_PASSWORD=admin   # Initial admin password

# === Kubernetes Mode (required for --k8s spawner) ===
# SICLAW_K8S_NAMESPACE=default
# SICLAW_AGENTBOX_IMAGE=siclaw-agentbox:latest
# SICLAW_BASE_URL=https://siclaw.example.com

# === SSO (optional, enables OIDC login) ===
# SICLAW_SSO_ISSUER=
# SICLAW_SSO_CLIENT_ID=
# SICLAW_SSO_CLIENT_SECRET=
# SICLAW_SSO_REDIRECT_URI=

# === S3 Storage (optional, for skill versions and session backups) ===
# SICLAW_S3_ENDPOINT=
# SICLAW_S3_BUCKET=
# SICLAW_S3_ACCESS_KEY=
# SICLAW_S3_SECRET_KEY=

# === Cron Service (optional, for scheduled tasks) ===
# SICLAW_CRON_SERVICE_URL=

# === AgentBox (set automatically in K8s mode) ===
# SICLAW_GATEWAY_URL=
# SICLAW_DEBUG_IMAGE=busybox:latest
# SICLAW_EMBEDDING_BASE_URL=
