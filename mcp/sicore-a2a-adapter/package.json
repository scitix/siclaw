{
  "name": "@scitix/sicore-a2a-mcp-adapter",
  "version": "0.1.0",
  "description": "Local stdio MCP adapter for one Sicore-hosted Siclaw A2A agent",
  "type": "module",
  "private": true,
  "bin": {
    "sicore-a2a-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
