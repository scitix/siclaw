  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.8",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "license": "Apache-2.0"
}
